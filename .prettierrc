{
  "tabWidth": 2,
  "printWidth": 80,
  "trailingComma": "all",
  "semi": true,
  "plugins": [
    "prettier-plugin-organize-imports",
    "prettier-plugin-tailwindcss"
  ],
  "tailwindFunctions": ["cn", "tw", "clsx"],
  "tailwindAttributes": [
    "class",
    "className",
    ".*Style",
    ".*Styles",
    ".*Props",
    ".*ClassName",
    ".*ClassNames",
    ".className",
    ".classNames",
    "style",
    "styles"
  ]
}
