{
  "name": "@fransek/ui",
  "version": "0.14.0",
  "type": "module",
  "private": false,
  "author": "Frans Ekman <fransedvinekman@gmail.com>",
  "license": "MIT",
  "description": "A design system and component library built on top of Base UI",
  "keywords": [],
  "homepage": "https://github.com/fransek/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fransek/ui"
  },
  "bugs": {
    "url": "https://github.com/fransek/ui/issues"
  },
  "files": [
    "dist"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "style": "dist/esm/theme.css",
  "exports": {
    ".": {
      "style": "./dist/esm/theme.css",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./theme.css": {
      "import": "./dist/esm/theme.css",
      "require": "./dist/cjs/theme.css"
    },
    "./*": {
      "import": "./dist/esm/components/*.js",
      "require": "./dist/cjs/components/*.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest --run --coverage --passWithNoTests",
    "lint": "eslint --fix src",
    "format": "prettier --write src",
    "validate": "tsc --noEmit && pnpm lint && pnpm format && pnpm test",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "clsx": "^2.1.1",
    "cssnano": "^7.1.9",
    "cssnano-preset-default": "^7.0.17",
    "date-fns": "^4.4.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.4.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-postcss": "^4.0.2",
    "semantic-release": "^25.0.5",
    "storybook": "^10.4.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.2.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.0.0",
    "lucide-react": "^0.575.0",
    "react": ">=19.0.0",
    "react-day-picker": "^9.0.0",
    "react-dom": ">=19.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-day-picker": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "bash -c tsc --noEmit"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
